{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "greentic": {
    "cardId": "ticket_closed",
    "flow": "on_event"
  },
  "body": [
    {
      "type": "Container",
      "style": "default",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "📁",
                  "size": "ExtraLarge"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Ticket Closed",
                  "size": "Large",
                  "weight": "Bolder"
                }
              ],
              "verticalContentAlignment": "Center"
            }
          ]
        }
      ]
    },
    {
      "type": "FactSet",
      "facts": [
        {
          "title": "Ticket ID",
          "value": "{{input.event.payload.ticket_id}}"
        },
        {
          "title": "Status",
          "value": "Closed"
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "This ticket has been closed. If you need further assistance, please create a new ticket.",
      "wrap": true,
      "spacing": "Medium"
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Create New Ticket",
      "data": {
        "action": "create_ticket"
      }
    }
  ]
}
