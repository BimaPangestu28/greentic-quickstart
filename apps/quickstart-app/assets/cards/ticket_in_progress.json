{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "greentic": {
    "cardId": "ticket_in_progress",
    "flow": "on_event"
  },
  "body": [
    {
      "type": "Container",
      "style": "accent",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "🔄",
                  "size": "ExtraLarge"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Ticket Update",
                  "size": "Large",
                  "weight": "Bolder",
                  "color": "Accent"
                }
              ],
              "verticalContentAlignment": "Center"
            }
          ]
        }
      ]
    },
    {
      "type": "FactSet",
      "facts": [
        {
          "title": "Ticket ID",
          "value": "{{input.event.payload.ticket_id}}"
        },
        {
          "title": "Status",
          "value": "In Progress"
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "{{input.event.payload.message}}",
      "wrap": true,
      "spacing": "Medium"
    },
    {
      "type": "TextBlock",
      "text": "Our team is working on your issue.",
      "wrap": true,
      "spacing": "Small",
      "isSubtle": true
    }
  ]
}
