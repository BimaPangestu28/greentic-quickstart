{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "greentic": {
    "cardId": "ticket_resolved",
    "flow": "on_event"
  },
  "body": [
    {
      "type": "Container",
      "style": "good",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "🎉",
                  "size": "ExtraLarge"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Ticket Resolved!",
                  "size": "Large",
                  "weight": "Bolder",
                  "color": "Good"
                }
              ],
              "verticalContentAlignment": "Center"
            }
          ]
        }
      ]
    },
    {
      "type": "FactSet",
      "facts": [
        {
          "title": "Ticket ID",
          "value": "{{input.event.payload.ticket_id}}"
        },
        {
          "title": "Issue",
          "value": "{{input.event.payload.issue}}"
        },
        {
          "title": "Status",
          "value": "Resolved"
        },
        {
          "title": "Resolved By",
          "value": "{{input.event.payload.resolved_by}}"
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "text": "Resolution",
          "weight": "Bolder",
          "color": "Accent"
        },
        {
          "type": "TextBlock",
          "text": "{{input.event.payload.resolution}}",
          "wrap": true
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Thank you for using our helpdesk!",
      "wrap": true,
      "spacing": "Medium",
      "horizontalAlignment": "Center",
      "isSubtle": true
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Feedback",
      "data": {
        "action": "feedback",
        "ticket_id": "{{input.event.payload.ticket_id}}"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Reopen Ticket",
      "data": {
        "action": "reopen",
        "ticket_id": "{{input.event.payload.ticket_id}}"
      }
    }
  ]
}
