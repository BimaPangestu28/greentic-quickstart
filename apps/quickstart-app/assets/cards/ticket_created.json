{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.3",
  "greentic": {
    "cardId": "ticket_created",
    "flow": "on_message"
  },
  "body": [
    {
      "type": "Container",
      "style": "good",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "✅",
                  "size": "ExtraLarge"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Ticket Created!",
                  "size": "Large",
                  "weight": "Bolder",
                  "color": "Good"
                }
              ],
              "verticalContentAlignment": "Center"
            }
          ]
        }
      ]
    },
    {
      "type": "FactSet",
      "facts": [
        {
          "title": "Ticket ID",
          "value": "{{ticket_id}}"
        },
        {
          "title": "Issue",
          "value": "{{issue_description}}"
        },
        {
          "title": "Status",
          "value": "Open"
        },
        {
          "title": "Priority",
          "value": "Normal"
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Our support team will review your ticket shortly. You'll receive a notification when there's an update.",
      "wrap": true,
      "spacing": "Medium"
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "View Ticket Status",
      "data": {
        "action": "view_ticket",
        "ticket_id": "{{ticket_id}}"
      }
    }
  ]
}
